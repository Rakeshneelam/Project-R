# ─── Database ───────────────────────────────────────
DATABASE_URL="postgresql://bondbridge:bondbridge_dev@localhost:5432/bondbridge?schema=public"

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=bondbridge_redis

# ─── JWT ────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── S3 / MinIO ────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=bondbridge_minio
S3_SECRET_KEY=bondbridge_minio_secret
S3_BUCKET=bondbridge-media
S3_REGION=us-east-1

# ─── App ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ─── Verification Provider ─────────────────────────
VERIFICATION_PROVIDER=mock
# DIGILOCKER_CLIENT_ID=
# DIGILOCKER_CLIENT_SECRET=
# DIGILOCKER_REDIRECT_URI=

# ─── Push Notifications ────────────────────────────
# EXPO_ACCESS_TOKEN=
# FCM_SERVER_KEY=

# ─── Admin ──────────────────────────────────────────
ADMIN_DASHBOARD_URL=http://localhost:3001
