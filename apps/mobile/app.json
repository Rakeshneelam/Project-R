{
  "expo": {
    "name": "BondBridge",
    "slug": "bondbridge",
    "version": "1.0.0",
    "scheme": "bondbridge",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bondbridge.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0F1A",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.bondbridge.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        { "photosPermission": "BondBridge needs access to your photos to upload media." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
